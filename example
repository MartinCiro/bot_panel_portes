USER_PANEL=mi_user
PASS_PANEL=mi_contra

HEADLESS=true        # true=sin navegador, false=navegador en primer plano
# CHROME_PATH=/usr/bin/google-chrome  # Opcional

# 🌐 URLs - MODO LOCAL (file://)
PANEL_BASE_URL=file:/
PANEL_LOGIN_URL=file:/
PANEL_PORTABILIDADES_URL=file:/

# ⏱️ Timeouts
TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=5.0

# 📁 Rutas
LOGS_PATH=./logs
DATA_PATH=./data

DISPLAY=0
PYTHONUNBUFFERED=1

# 📊 GOOGLE SHEETS
GSHEET_CREDENTIALS_PATH=./path_credential
GSHEET_SPREADSHEET_NAME=pt
GSHEET_WORKSHEET_NAME=pt2
GSHEET_SPREADSHEET_ID=id_SPREADSHEET

# 🔄 Comportamiento de escritura
GSHEET_APPEND_MODE=true        # true=agregar filas, false=sobrescribir hoja
GSHEET_INCLUDE_TIMESTAMP=true 
